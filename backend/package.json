{
  "name": "rag-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --max-old-space-size=4096 --expose-gc ./node_modules/.bin/ts-node src/index.ts",
    "dev-debug": "node --inspect --max-old-space-size=4096 --expose-gc ./node_modules/.bin/ts-node src/index.ts"
  },
  "dependencies": {
    "@langchain/mistralai": "^0.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.5",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
